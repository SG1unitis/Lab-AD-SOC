<group name="windows,sysmon,custom_rules,">

  <rule id="100004" level="10">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\WmiPrvSE\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|pwsh)\.exe$</field>
    <description>Suspicious shell execution spawned by WMI Provider Host</description>
    <mitre>
      <id>T1047</id>
      <id>T1059.001</id>
    </mitre>
  </rule>

</group>
